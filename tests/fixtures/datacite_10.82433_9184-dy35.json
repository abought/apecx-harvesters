      "descriptions": [
        {
          "lang": "en",
          "description": "The National Gallery houses one of the greatest collections of Western European painting. The Scientific Department researches the history of materials and techniques and their degradation mechanisms. This dataset contains a selected range of the data gathered from external sensors monitoring ambient light levels, temperature, relative humidity and air moisture content 24 hours a day, 7 days a week over the last two decades.",
          "descriptionType": "Abstract"
        }
